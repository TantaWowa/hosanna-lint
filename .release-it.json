{
  "git": {
    "commitMessage": "chore(release): v${version}",
    "tagName": "v${version}",
    "requireCleanWorkingDir": false,
    "push": true,
    "pushArgs": ["--follow-tags"]
  },
  "github": {
    "release": true,
    "releaseName": "v${version}",
    "draft": false
  },
  "npm": {
    "publish": true,
    "publishArgs": ["--access public"]
  },
  "hooks": {
    "after:bump": "npm run build && npm run lint && npm run test && (npm run changelog || echo 'WARNING: changelog generation failed (non-fatal)')",
    "before:release": "git add CHANGELOG.md",
    "after:release": "npm run release:bump-next ${version}"
  }
}
