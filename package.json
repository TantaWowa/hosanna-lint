{
  "name": "@tantawowa/hosanna-eslint-plugin",
  "version": "1.31.0-next",
  "description": "Custom ESLint rules for Hosanna UI",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "repository": {
    "url": "https://github.com/Tantawowa/hosanna-eslint-plugin.git"
  },
  "scripts": {
    "build": "rm -rf dist && tsc --project tsconfig.build.json && node scripts/generateBuildInfo.js",
    "test": "vitest --run --maxWorkers=20",
    "lint": "eslint --config eslint.config.mjs --ignore-pattern \"node_modules/**\" --ignore-pattern \"dist/**\" --ignore-pattern \"**/*.d.ts\" --ignore-pattern \"**/*.js\"",
    "lint-fix": "eslint --config eslint.config.mjs --ignore-pattern \"node_modules/**\" --ignore-pattern \"dist/**\" --ignore-pattern \"**/*.d.ts\" --ignore-pattern \"**/*.js\" --fix",
    "dev:watch": "nodemon --watch src --watch scripts --exec \"npm run build\" --ext ts,js,json",
    "changelog": "npx ai-changelog-generator --write",
    "changelog:dry": "npx ai-changelog-generator --dry-run",
    "release:patch": "bash scripts/release.sh patch",
    "release:minor": "bash scripts/release.sh minor",
    "release:major": "bash scripts/release.sh major",
    "release:patch:dry": "bash scripts/release.sh patch --dry-run",
    "release:minor:dry": "bash scripts/release.sh minor --dry-run",
    "release:major:dry": "bash scripts/release.sh major --dry-run",
    "release:bump-next": "node scripts/release-bump-next.js"
  },
  "keywords": [
    "eslint",
    "eslint-plugin",
    "hosanna",
    "roku",
    "typescript"
  ],
  "author": "Hosanna UI Team",
  "license": "ISC",
  "devDependencies": {
    "@types/eslint": "^8.56.10",
    "@types/node": "^24.5.2",
    "@typescript-eslint/parser": "^8.45.0",
    "ai-changelog-generator": "^0.2.0",
    "release-it": "^19.2.4",
    "eslint": "^9.17.0",
    "eslint-formatter-compact": "^8.40.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "nodemon": "^3.1.10",
    "typescript": "5.2.2",
    "typescript-eslint": "^8.18.1",
    "vitest": "^2.1.3"
  },
  "peerDependencies": {
    "eslint": ">=8.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@tantawowa/hosanna-supported-apis": "^1.8.0"
  }
}
